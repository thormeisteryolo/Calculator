<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Calculator.MainPage"
             Title="Kalkylator">
    <Grid RowDefinitions="Auto, *, *, *, *, *, *"
          ColumnDefinitions="*, *, *, *"
          Padding="10"
          ColumnSpacing="2"
          RowSpacing="2">
        <Entry x:Name="EntryCalculations"
               Grid.Row="0"
               Grid.ColumnSpan="4"
               IsReadOnly="True"
               FontSize="24"
               VerticalOptions="Center"
               BackgroundColor="White"
               TextColor="Black"
               HorizontalTextAlignment="End"/>

        <Entry x:Name="EntryResult"
               Grid.Row="1"
               Grid.ColumnSpan="4"
               IsReadOnly="True"
               FontSize="32"
               VerticalOptions="Center"
               BackgroundColor="White"
               TextColor="Black"
               HorizontalTextAlignment="End"/>

        <!-- Rad 1 -->
        <Button BackgroundColor="LightGray" Grid.Row="2" Grid.Column="0" Text="C" 
                Clicked="ClearButton" Pressed="PressedOnButton" Released="ReleaseButton"/>

        <Button BackgroundColor="LightGray" Grid.Row="2" Grid.Column="1" Text="M+" 
                Clicked="StoreInMemoryButton" Pressed="PressedOnButton" Released="ReleaseButton"/>

        <Button BackgroundColor="LightGray" Grid.Row="2" Grid.Column="2" Text="M-" 
                Clicked="CatchFromMemoryButton" Pressed="PressedOnButton" Released="ReleaseButton"/>

        <Button BackgroundColor="LightGray" Grid.Row="2" Grid.Column="3" Text="/" 
                Clicked="OperatorButton" Pressed="PressedOnButton" Released="ReleaseButton"/>

        <!-- Rad 2 -->
        <Button BackgroundColor="LightGray" Grid.Row="3" Grid.Column="0" Text="7" 
                Clicked="NumberButton" Pressed="PressedOnButton" Released="ReleaseButton"/>
        
        <Button BackgroundColor="LightGray" Grid.Row="3" Grid.Column="1" Text="8" 
                Clicked="NumberButton" Pressed="PressedOnButton" Released="ReleaseButton"/>
        
        <Button BackgroundColor="LightGray" Grid.Row="3" Grid.Column="2" Text="9" 
                Clicked="NumberButton" Pressed="PressedOnButton" Released="ReleaseButton"/>
        
        <Button BackgroundColor="LightGray" Grid.Row="3" Grid.Column="3" Text="*" 
                Clicked="OperatorButton" Pressed="PressedOnButton" Released="ReleaseButton"/>

        <!-- Rad 3 -->
        <Button BackgroundColor="LightGray" Grid.Row="4" Grid.Column="0" Text="4" 
                Clicked="NumberButton" Pressed="PressedOnButton" Released="ReleaseButton"/>
        
        <Button BackgroundColor="LightGray" Grid.Row="4" Grid.Column="1" Text="5" 
                Clicked="NumberButton" Pressed="PressedOnButton" Released="ReleaseButton"/>
        
        <Button BackgroundColor="LightGray" Grid.Row="4" Grid.Column="2" Text="6" 
                Clicked="NumberButton" Pressed="PressedOnButton" Released="ReleaseButton"/>
        
        <Button BackgroundColor="LightGray" Grid.Row="4" Grid.Column="3" Text="-" 
                Clicked="OperatorButton" Pressed="PressedOnButton" Released="ReleaseButton"/>

        <!-- Rad 4 -->
        <Button BackgroundColor="LightGray" Grid.Row="5" Grid.Column="0" Text="1" 
                Clicked="NumberButton" Pressed="PressedOnButton" Released="ReleaseButton"/>
        
        <Button BackgroundColor="LightGray" Grid.Row="5" Grid.Column="1" Text="2" 
                Clicked="NumberButton" Pressed="PressedOnButton" Released="ReleaseButton"/>
        
        <Button BackgroundColor="LightGray" Grid.Row="5" Grid.Column="2" Text="3" 
                Clicked="NumberButton" Pressed="PressedOnButton" Released="ReleaseButton"/>
        
        <Button BackgroundColor="LightGray" Grid.Row="5" Grid.Column="3" Text="+" 
                Clicked="OperatorButton" Pressed="PressedOnButton" Released="ReleaseButton"/>

        <!-- Rad 5 -->
        <Button BackgroundColor="LightGray" Grid.Row="6" Grid.Column="0" Text="-/+"
                Clicked="NegativeValue" Pressed="PressedOnButton" Released="ReleaseButton"/>

        <Button BackgroundColor="LightGray" Grid.Row="6" Grid.Column="1" Text="0" 
                Clicked="NumberButton"  Pressed="PressedOnButton" Released="ReleaseButton"/>
        
        <Button BackgroundColor="LightGray" Grid.Row="6" Grid.Column="2" Text="," 
                Clicked="NumberButton" Pressed="PressedOnButton" Released="ReleaseButton"/>
        
        <Button BackgroundColor="LimeGreen" Grid.Row="6" Grid.Column="3" Text="=" 
                Clicked="EqualButton" Pressed="PressedOnButton" Released="ReleaseButton"/>
    </Grid>
</ContentPage>
